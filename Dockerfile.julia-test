FROM julia:1.11

RUN apt-get update && apt-get install -y libhdf5-dev && rm -rf /var/lib/apt/lists/*

WORKDIR /app
COPY julia/Project.toml julia/Project.toml
RUN cd julia && julia --project=. -e 'using Pkg; Pkg.instantiate()'

COPY julia/ julia/
COPY python/tests/data/ python/tests/data/

WORKDIR /app/julia
CMD ["julia", "--project=.", "-e", "using Pkg; Pkg.test()"]
